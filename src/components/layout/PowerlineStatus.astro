---
import PowerSegment from '../ui/PowerSegment.astro';
import { siteConfig } from '../../lib/config/site';

const mode = Astro.url.pathname === '/' ? 'NORMAL' : 'VIEW';
const path = Astro.url.pathname === '/' ? '~/home' : `~${Astro.url.pathname}`;
---

<div class="statusline" aria-label="Editor status">
  <div class="left power-strip">
    <PowerSegment text={mode} tone="primary" />
    <PowerSegment text={path} tone="deep" />
    <PowerSegment text="main" tone="muted" />
  </div>
  <div class="status-meta">
    <span>{siteConfig.githubName}</span>
    <span>astro</span>
  </div>
</div>

<style>
  .statusline {
    --power-h: 1.75rem;
    --power-notch: 0.78rem;
    align-items: center;
    background: var(--bg-elevated);
    border-top: 1px solid var(--border-muted);
    color: var(--bg-base);
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    justify-content: space-between;
    min-height: var(--power-h);
    overflow: hidden;
  }

  .left {
    display: flex;
    overflow: hidden;
    min-width: 0;
  }

  .left :global(.power-segment:nth-child(2)) {
    max-width: min(52vw, 34rem);
  }

  .status-meta {
    align-items: center;
    background: var(--bg-hover);
    color: var(--text-muted);
    display: flex;
    font-size: 0.84rem;
    gap: 0;
    min-height: var(--power-h);
    min-width: 0;
    white-space: nowrap;
  }

  .status-meta span {
    border-left: 1px solid var(--border-muted);
    padding: 0 0.7rem;
  }

  @media (max-width: 680px) {
    .statusline {
      --power-h: 1.5rem;
      --power-notch: 0.58rem;
      font-size: 0.76rem;
    }

    .left :global(.power-segment:last-child),
    .status-meta span:last-child {
      display: none;
    }

    .left :global(.power-segment:nth-child(2)) {
      max-width: 48vw;
    }

    .status-meta span {
      padding: 0 0.45rem;
    }
  }

  @media (max-width: 400px) {
    .left :global(.power-segment:nth-child(2)) {
      max-width: 40vw;
    }
  }
</style>
