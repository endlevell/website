---
import { formatDate } from '../../lib/format/date';
import MarkdownBody from '../../components/ui/MarkdownBody.astro';
import BackLink from '../../components/ui/BackLink.astro';
import TagPill from '../../components/ui/TagPill.astro';
import TerminalWindow from '../../components/ui/TerminalWindow.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getPostBySlug } from '../../lib/db/queries';
import { renderMarkdown } from '../../lib/markdown/render';
import { blogPostJsonLd } from '../../lib/seo/jsonLd';

export const prerender = false;

const slug = Astro.params.slug ?? '';
const post = await getPostBySlug(slug);

if (!post) {
  Astro.response.status = 404;
}

const html = post ? await renderMarkdown(post.body) : '';
---

<BaseLayout
  title={post?.title ?? 'not found'}
  description={post?.excerpt ?? 'Post not found.'}
  ogType="article"
  jsonLd={post ? blogPostJsonLd(post) : undefined}
>
  <TerminalWindow path={post ? `~/blog/${post.slug}.md` : '~/404'}>
    {post ? (
      <article>
        <nav class="detail-nav" aria-label="Post navigation">
          <BackLink href="/blog" label="back ~/blog" />
        </nav>
        <header class="detail-head">
          <p class="section-label">$ less {post.slug}.md</p>
          <h1>{post.title}</h1>
          <p>{post.excerpt}</p>
          <time datetime={post.publishedAt?.toISOString()}>{formatDate(post.publishedAt)}</time>
          <div class="tags">
            {post.tagList.map((tag) => (
              <TagPill tag={tag} href={`/blog/tags/${tag}`} />
            ))}
          </div>
        </header>
        <MarkdownBody html={html} />
      </article>
    ) : (
      <section class="missing">
        <h1>command not found</h1>
        <p>bash: /blog/{slug}: no such file or directory</p>
        <a class="terminal-link" href="/blog">back to blog</a>
      </section>
    )}
  </TerminalWindow>
</BaseLayout>

<style>
  .detail-head {
    border-bottom: 1px solid var(--border-muted);
    margin-bottom: 1.5rem;
    padding-bottom: 1rem;
  }

  .detail-nav {
    margin-bottom: 1rem;
  }

  h1 {
    color: var(--text-strong);
    font-size: clamp(1.6rem, 4vw, 2.6rem);
    letter-spacing: 0;
    line-height: 1;
    margin: 0.25rem 0 0.8rem;
    max-width: 24ch;
  }

  .detail-head p:not(.section-label) {
    color: var(--text-muted);
    margin: 0;
    max-width: 72ch;
  }

  time {
    color: var(--accent-secondary);
    display: block;
    margin-top: 0.9rem;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem 0.5rem;
    margin-top: 0.8rem;
  }

  .missing p {
    color: var(--text-muted);
  }

  @media (max-width: 560px) {
    h1 {
      font-size: clamp(1.45rem, 9vw, 2rem);
      line-height: 1.08;
      max-width: none;
      overflow-wrap: anywhere;
    }
  }
</style>
