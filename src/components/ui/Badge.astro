---
type Props = {
  text: string;
  tone?: 'primary' | 'muted' | 'secondary' | 'base' | 'warning' | 'success' | 'magic';
  compact?: boolean;
  href?: string;
};

const { text, tone = 'secondary', compact = false, href } = Astro.props;
const classes = ['badge', `tone-${tone}`, { compact }];
---

{href ? <a class:list={classes} href={href}>{text}</a> : <span class:list={classes}>{text}</span>}

<style>
  .badge {
    --badge-bg: var(--bg-hover);
    --badge-fg: var(--text-default);
    align-items: center;
    background: var(--badge-bg);
    border: 1px solid var(--badge-border, var(--badge-bg));
    color: var(--badge-fg);
    display: inline-flex;
    font-size: 0.84rem;
    font-weight: 600;
    line-height: 1;
    min-height: 1.45rem;
    padding: 0 0.5rem;
    text-decoration: none;
    white-space: nowrap;
  }

  .compact {
    font-size: 0.78rem;
    min-height: 1.25rem;
    padding: 0 0.44rem;
  }

  .tone-primary {
    --badge-bg: var(--accent-primary);
    --badge-fg: var(--bg-base);
  }

  .tone-muted {
    --badge-bg: var(--bg-hover);
    --badge-border: var(--border-muted);
    --badge-fg: var(--text-muted);
  }

  .tone-secondary {
    --badge-bg: var(--accent-secondary);
    --badge-fg: var(--bg-base);
  }

  .tone-base {
    --badge-bg: var(--mocha-surface1);
    --badge-fg: var(--text-default);
  }

  .tone-warning {
    --badge-bg: var(--color-warning);
    --badge-fg: var(--bg-base);
  }

  .tone-success {
    --badge-bg: var(--color-success);
    --badge-fg: var(--bg-base);
  }

  .tone-magic {
    --badge-bg: var(--color-magic);
    --badge-fg: var(--bg-base);
  }

  a.badge:hover {
    color: var(--badge-fg);
    filter: brightness(1.08);
  }
</style>
