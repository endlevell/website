---
import AdminProjectForm from '../../../../components/admin/AdminProjectForm.astro';
import AdminLayout from '../../../../layouts/AdminLayout.astro';
import { getAdminProject } from '../../../../lib/admin/data';

export const prerender = false;

const id = Number(Astro.params.id);
const project = Number.isInteger(id) ? await getAdminProject(id) : null;

if (!project) {
  Astro.response.status = 404;
}
---

<AdminLayout title={project ? `edit ${project.title}` : 'project not found'}>
  {project ? (
    <>
      <header class="page-head">
        <p class="section-label">~/admin/projects/{project.id}/edit</p>
        <h1>edit project</h1>
      </header>
      <AdminProjectForm action={`/api/admin/projects/${project.id}`} project={project} />
    </>
  ) : (
    <section>
      <h1>project not found</h1>
      <a href="/admin/projects">back</a>
    </section>
  )}
</AdminLayout>

<style>
  h1 {
    color: var(--text-strong);
    margin: 0.2rem 0 1rem;
  }
</style>
