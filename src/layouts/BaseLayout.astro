---
import { ClientRouter } from 'astro:transitions';
import Font from 'astro/components/Font.astro';
import CommandNav from '../components/layout/CommandNav.astro';
import Footer from '../components/layout/Footer.astro';
import PowerlineStatus from '../components/layout/PowerlineStatus.astro';
import SEO from '../components/layout/SEO.astro';
import '../styles/global.css';

type Props = {
  title: string;
  description?: string;
  canonical?: string;
  ogType?: 'website' | 'article';
  ogImage?: string | null;
  noindex?: boolean;
  jsonLd?: unknown;
};

const props = Astro.props;
const isHome = Astro.url.pathname === '/';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#1e1e2e" />
    <Font cssVariable="--font-mono" preload={true} />
    <SEO {...props} />
    <ClientRouter />
  </head>
  <body>
    <a class="skip-link" href="#main">skip to content</a>
    <div class:list={['page-shell', { 'page-shell-home': isHome }]}>
      <div class="tui-screen">
        <CommandNav />
        <main id="main" class="tui-workspace">
          <slot />
        </main>
        <div>
          <PowerlineStatus />
          <Footer />
        </div>
      </div>
    </div>
    <script>
      import '../scripts/motion';
    </script>
  </body>
</html>
