---
import ProjectList from '../../components/projects/ProjectList.astro';
import TerminalWindow from '../../components/ui/TerminalWindow.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getProjects } from '../../lib/db/queries';

export const prerender = false;

const projects = await getProjects();
---

<BaseLayout title="projects" description="Project notes and experiments from endlevel.">
  <TerminalWindow path="~/projects">
    <header class="page-head">
      <p class="section-label">$ ls -la ~/projects</p>
      <h1>projects</h1>
      <p>Systems sketches, Linux experiments, and small programs kept close to the metal.</p>
    </header>
    <ProjectList projects={projects} />
  </TerminalWindow>
</BaseLayout>

<style>
  .page-head {
    margin-bottom: 1.5rem;
  }

  h1 {
    color: var(--text-strong);
    font-size: clamp(1.6rem, 4vw, 2.6rem);
    letter-spacing: 0;
    line-height: 1;
    margin: 0.25rem 0 0.7rem;
  }

  .page-head p:last-child {
    color: var(--text-muted);
    margin: 0;
    max-width: 70ch;
  }
</style>
